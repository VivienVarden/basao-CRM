# ╔══════════════════════════════════════════════════════════════════╗
# ║   HƯỚNG DẪN SETUP — Sao chép file này thành .env.local          ║
# ║   KHÔNG commit .env.local lên git!                               ║
# ╠══════════════════════════════════════════════════════════════════╣
# ║                                                                  ║
# ║  BƯỚC 1: cp .env.local.example .env.local                       ║
# ║  BƯỚC 2: Điền các giá trị thực vào .env.local                   ║
# ║  BƯỚC 3: Restart dev server                                      ║
# ║                                                                  ║
# ║  GOOGLE OAUTH (tùy chọn):                                        ║
# ║    Truy cập https://console.cloud.google.com                     ║
# ║    APIs & Services → Credentials → OAuth 2.0 Client ID          ║
# ║    Authorized redirect: http://localhost:3000/api/auth/callback  ║
# ║                                                                  ║
# ║  PASSWORD HASH: chạy lệnh sau để tạo hash cho mật khẩu mới:    ║
# ║    node -e "console.log(require('bcryptjs').hashSync('PWD',12))" ║
# ╚══════════════════════════════════════════════════════════════════╝

# Google OAuth (không bắt buộc nếu dùng Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Secret — PHẢI THAY = chạy: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_YOUR_OWN_SECRET
NEXTAUTH_URL=http://localhost:3000

# Credentials đăng nhập — hash bằng bcrypt (salt=12)
# Xem hướng dẫn hash ở trên
ADMIN_USERNAME=Trung
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

SALES_USERNAME=Sale01
SALES_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH
